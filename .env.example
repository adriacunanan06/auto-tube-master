# Auto-Tube API Keys

# 1. Gemini API Key (Free)
# Get it from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# 2. ElevenLabs API Key (Free tier available)
# Get it from: https://elevenlabs.io/app/voice-lab -> Profile -> API Key
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB # Default Adam voice

# 3. Pexels API Key (Free)
# Get it from: https://www.pexels.com/api/new/
PEXELS_API_KEY=your_pexels_api_key_here

# 4. YouTube OAuth Credentials (for later)
# See instructions to set up Google Cloud OAuth client
YOUTUBE_CLIENT_ID=your_client_id
YOUTUBE_CLIENT_SECRET=your_client_secret
YOUTUBE_REDIRECT_URI=http://localhost:3000/oauth2callback
