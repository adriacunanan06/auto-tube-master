# -----------------------------
# Core AI provider (required for high-quality autonomous scripts)
# -----------------------------
# Choose: gemini or openai
LLM_PROVIDER=gemini

# Gemini API (recommended if you already use Gemini)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro

# OpenAI API (optional fallback)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# -----------------------------
# Voice generation
# -----------------------------
# If ELEVENLABS_API_KEY is empty, tool falls back to free edge-tts
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=eleven_multilingual_v2
EDGE_TTS_VOICE=en-US-AriaNeural

# -----------------------------
# B-roll image source
# -----------------------------
# Optional: if empty, the tool generates local branded slides automatically
PEXELS_API_KEY=

# -----------------------------
# YouTube upload (optional for full autopilot)
# -----------------------------
# Path to OAuth client secrets JSON from Google Cloud Console
YOUTUBE_CLIENT_SECRETS_FILE=
# Token output path generated after first auth
YOUTUBE_TOKEN_FILE=youtube_token.json
YOUTUBE_DEFAULT_PRIVACY=private

# -----------------------------
# Defaults for runs
# -----------------------------
DEFAULT_NICHE=personal finance
DEFAULT_AUDIENCE=English-speaking adults in US/UK/CA
DEFAULT_FORMAT=short
DEFAULT_DURATION_SECONDS=55
DEFAULT_IMAGE_COUNT=8
DEFAULT_BATCH_SIZE=1
DEFAULT_BATCH_SLEEP_SECONDS=3
TRENDS_GEO=US
